# AI Video Creator - Backend Configuration

# Server Port
PORT=5000

# Frontend origin(s) for CORS (comma-separated). In NODE_ENV=production, only these origins are allowed.
# Outside production, http(s)://localhost:* and http(s)://127.0.0.1:* are also accepted.
FRONTEND_ORIGIN=http://localhost:3000

# Authentication Secret (Change this to a secure random string in production)
JWT_SECRET=your_super_secret_jwt_key_here

# AI provider: openai (default) or google — used for storyboard text + /llm only
AI_PROVIDER=openai

# OpenAI — required for GPT Image / image API, Videos API (Sora), and (when AI_PROVIDER=openai) storyboards
OPENAI_API_KEY=your_openai_api_key_here
# Optional: custom API base (default https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google AI Studio — only if you set AI_PROVIDER=google for storyboards/LLM (https://aistudio.google.com/apikey)
# GEMINI_API_KEY=your_google_ai_studio_key_here

# Story models
OPENAI_STORY_MODEL=gpt-4o-mini
GOOGLE_STORY_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# OpenAI image model — ONE switch for the whole app (generate + edit)
# ---------------------------------------------------------------------------
# All image generation and reference-image editing use this model only.
# Backend: `getOpenAIImageModel()` in lib/aiClient.js — do not hardcode models elsewhere.
# Public echo (no secrets): GET /api/health returns `openaiImageModel` with the resolved value.
#
# Examples (check current OpenAI docs for availability): gpt-image-2, gpt-image-1.5,
# gpt-image-1, gpt-image-1-mini, chatgpt-image-latest, dall-e-3, dall-e-2
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=auto
# Optional: GPT Image edit — high | low (how closely to match a reference upload)
# OPENAI_IMAGE_INPUT_FIDELITY=high

# Video: OpenAI Videos API (Sora). “Veo” is Google’s model; on OpenAI this is sora-2 / sora-2-pro.
# Docs: https://platform.openai.com/docs/api-reference/videos
OPENAI_VIDEO_MODEL=sora-2

VIDEO_POLL_MS=5000
VIDEO_MAX_WAIT_MS=600000

# SMTP Configuration (For sending invite emails and notifications)
# Example using Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_specific_password
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# File Upload Directory (Relative to backend folder)
UPLOAD_DIR=uploads
