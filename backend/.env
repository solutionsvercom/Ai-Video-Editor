PORT=5000
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# OpenAI for LLM and Image Generation
OPENAI_API_KEY=OPENAI_API_KEY
GEMINI_API_KEY=GEMINI_API_KEY
